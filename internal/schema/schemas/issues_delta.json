{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["add", "retract", "update", "support", "withdraw", "contest"],
  "properties": {
    "add": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "file", "title", "description"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "nitpick"]
          },
          "category": { "type": "string" },
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "suggestedFix": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "retract": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "update": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "nitpick"]
          },
          "category": { "type": "string" },
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "suggestedFix": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "support": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issueRef"],
        "properties": {
          "issueRef": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "withdraw": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issueRef"],
        "properties": {
          "issueRef": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "contest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issueRef"],
        "properties": {
          "issueRef": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
